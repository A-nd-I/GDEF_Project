MODEL=gpt-oss:20b
API_KEY=ollama
BASE_URL=http://localhost:11434/v1

INPUT_FILE=data/dataset_laws_col.csv
OUTPUT_DIR=outputs

COUNTRY=all                   # match the `country` column literally, or `all`
LANGUAGE=all                  # match the `language` column literally (e.g. Spanish), or `all`
NUM=                          # empty = all; integer = first N

TEMPERATURE=0.8
SEED=                         # empty = random; integer = reproducible

TIMEOUT_SECONDS=300
PAUSE_BETWEEN=0
DRY_RUN=                      # 1 to exercise the pipeline without calling the model